   "source": [
    "def letters(letter):\n",
    "    l = 'a'\n",
    "    while(ord(l) < ord(letter)):\n",
    "        yield l\n",
    "        l = chr(ord(l)+1)\n",
    "\n",
    "for letter in letters('f'):\n",
    "    print(letter)"
   ]
